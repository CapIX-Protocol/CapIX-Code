{
  "name": "capix-code",
  "version": "1.1.0",
  "description": "Capix Code — AI coding agent with smart routing",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "compile": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-sdk/provider": "3.0.8",
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "bun": "^1.3.14",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "opencode-ai": "1.17.18",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capix/runtime-provider": "file:packages/runtime-provider",
    "@opencode-ai/plugin": "1.17.18",
    "@opencode-ai/sdk": "1.17.18"
  }
}
