# Capix Code — Environment Variables
CAPIX_BASE_URL=https://capix.network/api/v1
CAPIX_API_KEY=your-api-key-here
CAPIX_MODEL=anthropic/claude-sonnet-4-20250514
CAPIX_ROUTE_MODE=auto

# Solana settlement (read-only inspection; the CLI never holds keypairs —
# signing is delegated to your web wallet).
CAPIX_SOLANA_RPC=https://api.devnet.solana.com
CAPIX_SOLANA_CLUSTER=devnet
CAPIX_CPX_MINT=
CAPIX_CPX_DECIMALS=9
CAPIX_SETTLEMENT_PROGRAM_ID=
